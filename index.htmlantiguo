<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Diario de Trading Pro v10</title>
  <meta name="theme-color" content="#06101f" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Diario Trading" />
  <link rel="manifest" href="./manifest.json?v=10" />
  <link rel="icon" type="image/png" sizes="192x192" href="./icon-192.png?v=10" />
  <style>
    :root{
      --bg:#06101f;--bg2:#08162b;--panel:#0d1b31;--panel2:#0b1730;--line:#22314e;--text:#eef4ff;--muted:#9fb0cc;
      --blue:#5ea8ff;--blue2:#3f85db;--good:#7bffbf;--bad:#ff7b9c;--warn:#ffd166;--chip:#132643;--input:#f7fbff;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Cantarell,Noto Sans,sans-serif;background:linear-gradient(180deg,var(--bg),var(--bg2));color:var(--text)}
    .wrap{max-width:1280px;margin:0 auto;padding:20px}
    h1{margin:0;font-size:32px}
    .sub{color:var(--muted);margin-top:6px}
    .grid-4,.grid-3,.grid-2,.form-grid,.mini-grid{display:grid;gap:16px}
    .grid-4{grid-template-columns:repeat(4,1fr)}
    .grid-3{grid-template-columns:2fr 1fr 1fr}
    .grid-2{grid-template-columns:2fr 1fr}
    .form-grid{grid-template-columns:repeat(2,1fr);gap:14px}
    .mini-grid{grid-template-columns:repeat(2,1fr);gap:12px}
    .card{background:linear-gradient(180deg,var(--panel),var(--panel2));border:1px solid var(--line);border-radius:24px;padding:18px;box-shadow:0 10px 30px rgba(0,0,0,.18)}
    .metric .k,.hint,.muted{color:var(--muted)} .metric .k{font-size:14px} .metric .v{font-size:30px;font-weight:800;margin-top:6px}
    .section{font-size:14px;letter-spacing:.18em;text-transform:uppercase;color:#a9c8ff;margin:0 0 14px;font-weight:800}
    .tabs,.filters,.toggle-row,.actions,.pill-row{display:flex;gap:10px;flex-wrap:wrap}
    .tab,.btn,.toggle,.pill{border:none;border-radius:16px;padding:12px 16px;background:#13233f;color:var(--text);font-weight:700;cursor:pointer}
    .tab.active,.btn.primary,.toggle.active,.pill.active{background:linear-gradient(180deg,var(--blue),var(--blue2))}
    .btn.secondary{background:#113457}.btn.ghost{background:#13233f}.btn.small{padding:8px 12px;border-radius:12px;font-size:13px}
    .field{display:flex;flex-direction:column;gap:7px}.field.full{grid-column:1/-1}
    label{font-size:14px;font-weight:700}
    input,select,textarea{width:100%;border:none;border-radius:14px;padding:14px;background:var(--input);color:#0d1b31;font-size:16px}
    textarea{min-height:110px;resize:vertical}
    .mini{background:#081223;border:1px solid var(--line);border-radius:18px;padding:14px}
    .mini .k{font-size:13px;color:var(--muted)} .mini .v{font-size:25px;font-weight:800;margin-top:4px}
    .quick .row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.06)} .quick .row:last-child{border-bottom:none}
    .history{display:flex;flex-direction:column;gap:12px}
    .trade{border:1px solid var(--line);border-radius:20px;padding:16px;background:#091425}
    .trade-top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;flex-wrap:wrap}
    .badges{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
    .badge{padding:6px 10px;border-radius:999px;background:var(--chip);color:#d6e5ff;font-size:12px;font-weight:700;border:1px solid #27466d}
    .good{color:var(--good)!important}.bad{color:var(--bad)!important}
    .tabs-panel{margin-top:18px}.hidden{display:none}
    .edit-banner{background:#173258;border:1px solid #305b96;border-radius:16px;padding:10px 14px;margin-bottom:14px}
    .legend{font-size:12px;color:var(--muted);margin-top:8px}
    .chart-box{height:280px}
    .ticker-btn{background:none;border:none;color:#6fb3ff;text-decoration:underline;cursor:pointer;font-size:22px;font-weight:800;padding:0}
    .spacer{flex:1}.split{border-top:1px solid rgba(255,255,255,.08);margin:18px 0}
    @media (max-width:980px){.grid-4,.grid-3,.grid-2,.form-grid,.mini-grid{grid-template-columns:1fr}.wrap{padding:14px}h1{font-size:26px}}
  </style>
</head>
<body>
<div class="wrap">
  <h1>Diario de Trading Pro v10</h1>
  <div class="sub">Compra y venta simétricas, importes calculados, panel visual, historial, edición y sin service worker.</div>

  <div class="grid-4" style="margin-top:18px">
    <div class="card metric"><div class="k">Operaciones</div><div id="mOps" class="v">0</div></div>
    <div class="card metric"><div class="k">Resultado EUR</div><div id="mEur" class="v">0 €</div></div>
    <div class="card metric"><div class="k">Resultado USD</div><div id="mUsd" class="v">0 $</div></div>
    <div class="card metric"><div class="k">Win rate</div><div id="mWr" class="v">0%</div></div>
  </div>

  <div class="filters tabs-panel">
    <button class="tab active" data-filter="todos">Todo</button>
    <button class="tab" data-filter="semana">Semana</button>
    <button class="tab" data-filter="mes">Mes</button>
  </div>

  <div class="tabs tabs-panel">
    <button class="tab active" data-view="nuevo">Nueva operación</button>
    <button class="tab" data-view="panel">Panel visual</button>
    <button class="tab" data-view="historial">Historial</button>
  </div>

  <div id="view-nuevo" class="view">
    <div class="grid-2" style="margin-top:16px">
      <div class="card">
        <div id="editBanner" class="edit-banner hidden">
          Estás editando una operación.
          <button class="btn small ghost" type="button" onclick="cancelarEdicion()">Cancelar edición</button>
        </div>

        <div class="field" style="margin-bottom:14px">
          <label>Estado de la operación</label>
          <div class="toggle-row">
            <button class="toggle active" data-estado="abierta" type="button">Abierta</button>
            <button class="toggle" data-estado="parcial" type="button">Parcial</button>
            <button class="toggle" data-estado="cerrada" type="button">Cerrada</button>
          </div>
          <div class="hint">Abierta: sin venta todavía. Parcial: vendiste una parte. Cerrada: vendiste todo.</div>
        </div>

        <div class="section">Compra</div>
        <div class="form-grid">
          <div class="field"><label>Fecha compra</label><input id="fechaCompra" type="date"></div>
          <div class="field"><label>Instrumento</label><input id="instrumento" placeholder="Ej: NVDA"></div>

          <div class="field"><label>Dirección</label><select id="direccion"><option>Largo</option><option>Corto</option></select></div>
          <div class="field"><label>Moneda</label><select id="moneda"><option value="EUR">EUR</option><option value="USD" selected>USD</option></select></div>

          <div class="field"><label>Precio compra</label><input id="precioCompra" type="number" step="0.0001" placeholder="Precio por acción"></div>
          <div class="field"><label>Cantidad comprada</label><input id="cantidadCompra" type="number" step="0.0001" placeholder="Acciones o contratos"></div>

          <div class="field"><label>Importe compra manual (solo si no pones cantidad)</label><input id="importeCompraManual" type="number" step="0.01" placeholder="Opcional"></div>
          <div class="field"><label>Importe compra calculado</label><input id="importeCompraCalc" type="text" readonly></div>

          <div class="field"><label>Stop loss (opcional)</label><input id="stop" type="number" step="0.0001" placeholder="Nivel de stop"></div>
          <div class="field"><label>Take profit previsto (opcional)</label><input id="tp" type="number" step="0.0001" placeholder="Objetivo previsto"></div>

          <div class="field"><label>Motivo entrada</label><select id="motivoEntrada"><option>Ruptura</option><option>Pullback</option><option>Añadir posición</option><option>Promediar</option><option>Rebote en soporte</option><option>Giro de tendencia</option><option>Otra</option></select></div>
          <div class="field full"><label>Notas entrada</label><textarea id="notasEntrada" placeholder="Contexto, plan, por qué entraste..."></textarea></div>
        </div>

        <div class="split"></div>

        <div class="section" style="color:#ffd79a">Venta</div>
        <div class="form-grid">
          <div class="field"><label>Fecha venta</label><input id="fechaVenta" type="date"></div>
          <div class="field"><label>Precio venta</label><input id="precioVenta" type="number" step="0.0001" placeholder="Precio por acción"></div>

          <div class="field"><label>Cantidad vendida</label><input id="cantidadVendida" type="number" step="0.0001" placeholder="Acciones vendidas"></div>
          <div class="field"><label>Importe venta calculado</label><input id="importeVentaCalc" type="text" readonly></div>

          <div class="field"><label>Motivo salida</label><select id="motivoSalida"><option>Sin salida aún</option><option>Take profit</option><option>Stop loss</option><option>Salida manual</option><option>Reducción de riesgo</option><option>Cierre parcial</option><option>Cambio de escenario</option><option>Otra</option></select></div>
          <div class="field full"><label>Notas salida</label><textarea id="notasSalida" placeholder="Cómo saliste, por qué, si fue parcial, etc."></textarea></div>
        </div>

        <div class="section" style="margin-top:22px;color:#d8b3ff">Riesgo</div>
        <div class="pill-row">
          <button class="pill active" data-risk="1" type="button">1%</button>
          <button class="pill" data-risk="2" type="button">2%</button>
          <button class="pill" data-risk="3" type="button">3%</button>
        </div>

        <div class="actions" style="margin-top:18px">
          <button id="guardar" class="btn primary" type="button">Guardar operación</button>
          <button id="limpiar" class="btn ghost" type="button">Limpiar formulario</button>
          <div class="spacer"></div>
          <button id="exportar" class="btn secondary" type="button">Exportar JSON</button>
          <label class="btn ghost" for="importar">Importar JSON</label>
          <input id="importar" class="hidden" type="file" accept=".json">
        </div>
      </div>

      <div class="card">
        <div class="section">Panel visual</div>
        <div class="mini-grid">
          <div class="mini"><div class="k">Importe compra</div><div id="vCompra" class="v">0 €</div></div>
          <div class="mini"><div class="k">Importe venta</div><div id="vVenta" class="v">0 €</div></div>
          <div class="mini"><div class="k">Riesgo permitido</div><div id="vRiesgoPermitido" class="v" style="color:var(--warn)">0 €</div></div>
          <div class="mini"><div class="k">Riesgo real</div><div id="vRiesgoReal" class="v" style="color:var(--bad)">—</div></div>
          <div class="mini"><div class="k">Resultado realizado</div><div id="vResultado" class="v" style="color:var(--good)">—</div></div>
          <div class="mini"><div class="k">Resultado objetivo</div><div id="vObjetivo" class="v">—</div></div>
        </div>

        <div class="card" style="margin-top:16px;padding:14px;border-radius:18px;background:#081223">
          <div class="section" style="margin-bottom:8px">Vista rápida</div>
          <div class="quick">
            <div class="row"><span class="muted">Estado</span><strong id="qEstado">Abierta</strong></div>
            <div class="row"><span class="muted">Instrumento</span><strong id="qInstrumento">—</strong></div>
            <div class="row"><span class="muted">Dirección</span><strong id="qDireccion">Largo</strong></div>
            <div class="row"><span class="muted">Moneda</span><strong id="qMoneda">USD</strong></div>
            <div class="row"><span class="muted">Precio compra</span><strong id="qPrecioCompra">—</strong></div>
            <div class="row"><span class="muted">Cantidad comprada</span><strong id="qCantidadCompra">—</strong></div>
            <div class="row"><span class="muted">Precio venta</span><strong id="qPrecioVenta">—</strong></div>
            <div class="row"><span class="muted">Cantidad vendida</span><strong id="qCantidadVendida">—</strong></div>
            <div class="row"><span class="muted">Stop</span><strong id="qStop">—</strong></div>
            <div class="row"><span class="muted">Take profit</span><strong id="qTp">—</strong></div>
          </div>
        </div>
        <div class="legend">Esta versión debe dejar muy claro si ha entrado el cambio: verás el bloque Venta completo y los importes calculados.</div>
      </div>
    </div>
  </div>

  <div id="view-panel" class="view hidden">
    <div class="grid-3" style="margin-top:16px">
      <div class="card"><div class="section">Curva de capital</div><div id="equityChart" class="chart-box"></div></div>
      <div class="card">
        <div class="section">Balance rápido</div>
        <div class="mini"><div class="k">Ganadoras</div><div class="v good" id="bGanadoras">0</div></div>
        <div class="mini" style="margin-top:12px"><div class="k">Perdedoras</div><div class="v bad" id="bPerdedoras">0</div></div>
        <div class="mini" style="margin-top:12px"><div class="k">EUR</div><div class="v" id="bEur">0 €</div></div>
        <div class="mini" style="margin-top:12px"><div class="k">USD</div><div class="v" id="bUsd">0 $</div></div>
      </div>
      <div class="card"><div class="section">Motivos más usados</div><div id="motivosChart"></div></div>
    </div>
  </div>

  <div id="view-historial" class="view hidden">
    <div class="card" style="margin-top:16px">
      <div class="section">Historial de operaciones</div>
      <div id="history" class="history"></div>
    </div>
  </div>
</div>

<script>
const KEY='diario_trading_pro_v10';
let trades=load(), filtro='todos', vista='nuevo', estadoOperacion='abierta', riesgoPct=1, editingId=null;

function hoyISO(o=0){const d=new Date();d.setDate(d.getDate()+o);return d.toISOString().slice(0,10)}
function num(v){return Number(v||0)}
function money(n,m){return new Intl.NumberFormat('es-ES',{style:'currency',currency:m==='EUR'?'EUR':'USD'}).format(Number(n||0))}
function esc(s){return String(s).replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))}
function fmtNum(n){return n?new Intl.NumberFormat('es-ES',{maximumFractionDigits:4}).format(Number(n)):'—'}
function load(){const raw=localStorage.getItem(KEY); if(!raw) return []; try{return JSON.parse(raw)}catch{return []}}
function save(){localStorage.setItem(KEY, JSON.stringify(trades)); render()}

function cantidadComprada(t){
  if(num(t.cantidadCompra)>0) return num(t.cantidadCompra);
  return num(t.precioCompra)>0 && num(t.importeCompraManual)>0 ? num(t.importeCompraManual)/num(t.precioCompra) : 0;
}
function importeCompra(t){
  const q=cantidadComprada(t);
  if(q>0 && num(t.precioCompra)>0) return q*num(t.precioCompra);
  return num(t.importeCompraManual)||0;
}
function cantidadVendida(t){
  const base=cantidadComprada(t);
  return num(t.cantidadVendida)>0 ? num(t.cantidadVendida) : ((t.estado||'abierta')==='cerrada' ? base : 0);
}
function importeVenta(t){
  const q=cantidadVendida(t);
  return q>0 && num(t.precioVenta)>0 ? q*num(t.precioVenta) : 0;
}
function riesgoRealTrade(t){
  const q=cantidadComprada(t);
  if(!q || !num(t.precioCompra) || !num(t.stop)) return 0;
  return Math.abs(num(t.precioCompra)-num(t.stop))*q;
}
function resultadoObjetivoTrade(t){
  const q=cantidadComprada(t);
  if(!q || !num(t.precioCompra) || !num(t.tp)) return 0;
  return (t.direccion==='Largo' ? (num(t.tp)-num(t.precioCompra)) : (num(t.precioCompra)-num(t.tp))) * q;
}
function resultadoTrade(t){
  if((t.estado||'abierta')==='abierta') return 0;
  const q=cantidadVendida(t);
  if(!q || !num(t.precioCompra) || !num(t.precioVenta)) return 0;
  return (t.direccion==='Largo' ? (num(t.precioVenta)-num(t.precioCompra)) : (num(t.precioCompra)-num(t.precioVenta))) * q;
}
function sameWeek(iso){const d=new Date(iso+'T00:00:00');const now=new Date();const day=(now.getDay()+6)%7;const start=new Date(now);start.setDate(now.getDate()-day);start.setHours(0,0,0,0);return d>=start&&d<=now}
function filtered(){ if(filtro==='semana') return trades.filter(t=>sameWeek(t.fechaCompra)); if(filtro==='mes'){ const ym=(new Date()).toISOString().slice(0,7); return trades.filter(t=>(t.fechaCompra||'').startsWith(ym)); } return [...trades]; }
function summary(list){
  const cerradas=list.filter(t=>(t.estado||'abierta')!=='abierta');
  const results=cerradas.map(t=>({moneda:t.moneda||'USD',valor:resultadoTrade(t)}));
  return {eur:results.filter(x=>x.moneda==='EUR').reduce((a,b)=>a+b.valor,0),usd:results.filter(x=>x.moneda!=='EUR').reduce((a,b)=>a+b.valor,0),ganadoras:results.filter(x=>x.valor>0).length,perdedoras:results.filter(x=>x.valor<0).length,winRate:cerradas.length?Math.round((results.filter(x=>x.valor>0).length/cerradas.length)*100):0,operaciones:list.length};
}
function setText(id,v){document.getElementById(id).textContent=v}

function applyEstadoUI(){
  document.querySelectorAll('.toggle').forEach(btn=>btn.classList.toggle('active',btn.dataset.estado===estadoOperacion));
  const isOpen=estadoOperacion==='abierta';
  ['fechaVenta','precioVenta','cantidadVendida'].forEach(id=>document.getElementById(id).closest('.field').classList.toggle('hidden',isOpen));
  const motivo=document.getElementById('motivoSalida');
  if(isOpen) motivo.value='Sin salida aún';
  else if(estadoOperacion==='parcial' && motivo.value==='Sin salida aún') motivo.value='Cierre parcial';
  else if(estadoOperacion==='cerrada' && motivo.value==='Sin salida aún') motivo.value='Take profit';
  updatePreview();
}

function bindForm(){
  document.getElementById('fechaCompra').value=hoyISO();
  ['fechaCompra','instrumento','direccion','moneda','precioCompra','cantidadCompra','importeCompraManual','stop','tp','motivoEntrada','notasEntrada','fechaVenta','precioVenta','cantidadVendida','motivoSalida','notasSalida'].forEach(id=>{
    document.getElementById(id).addEventListener('input',updatePreview);
    document.getElementById(id).addEventListener('change',updatePreview);
  });
  document.querySelectorAll('.pill').forEach(btn=>btn.addEventListener('click',()=>{document.querySelectorAll('.pill').forEach(b=>b.classList.remove('active'));btn.classList.add('active');riesgoPct=Number(btn.dataset.risk);updatePreview();}));
  document.querySelectorAll('.toggle').forEach(btn=>btn.addEventListener('click',()=>{estadoOperacion=btn.dataset.estado;applyEstadoUI();}));
  applyEstadoUI();
}

function formData(){
  return {
    id: editingId || Date.now(),
    estado: estadoOperacion,
    fechaCompra: document.getElementById('fechaCompra').value || hoyISO(),
    instrumento: document.getElementById('instrumento').value.trim().toUpperCase(),
    direccion: document.getElementById('direccion').value,
    moneda: document.getElementById('moneda').value,
    precioCompra: num(document.getElementById('precioCompra').value),
    cantidadCompra: num(document.getElementById('cantidadCompra').value),
    importeCompraManual: num(document.getElementById('importeCompraManual').value),
    stop: num(document.getElementById('stop').value),
    tp: num(document.getElementById('tp').value),
    motivoEntrada: document.getElementById('motivoEntrada').value,
    notasEntrada: document.getElementById('notasEntrada').value.trim(),
    fechaVenta: document.getElementById('fechaVenta').value,
    precioVenta: num(document.getElementById('precioVenta').value),
    cantidadVendida: num(document.getElementById('cantidadVendida').value),
    motivoSalida: document.getElementById('motivoSalida').value,
    notasSalida: document.getElementById('notasSalida').value.trim()
  };
}

function updatePreview(){
  const f=formData();
  const compra=importeCompra(f), venta=importeVenta(f), riesgoPermitido=compra*(riesgoPct/100), riesgoReal=riesgoRealTrade(f), objetivo=resultadoObjetivoTrade(f), realizado=resultadoTrade(f);
  document.getElementById('importeCompraCalc').value=money(compra,f.moneda);
  document.getElementById('importeVentaCalc').value=money(venta,f.moneda);
  setText('vCompra', money(compra,f.moneda));
  setText('vVenta', money(venta,f.moneda));
  setText('vRiesgoPermitido', money(riesgoPermitido,f.moneda));
  setText('vRiesgoReal', riesgoReal?money(riesgoReal,f.moneda):'—');
  setText('vResultado', (f.estado!=='abierta'&&venta)?money(realizado,f.moneda):'—');
  setText('vObjetivo', objetivo?money(objetivo,f.moneda):'—');
  setText('qEstado', f.estado.charAt(0).toUpperCase()+f.estado.slice(1));
  setText('qInstrumento', f.instrumento || '—');
  setText('qDireccion', f.direccion || '—');
  setText('qMoneda', f.moneda || '—');
  setText('qPrecioCompra', f.precioCompra || '—');
  setText('qCantidadCompra', cantidadComprada(f)?fmtNum(cantidadComprada(f)):'—');
  setText('qPrecioVenta', f.estado==='abierta'?'—':(f.precioVenta || '—'));
  setText('qCantidadVendida', f.estado==='abierta'?'—':(cantidadVendida(f)?fmtNum(cantidadVendida(f)):'—'));
  setText('qStop', f.stop || '—');
  setText('qTp', f.tp || '—');
}

function limpiarFormularioBase(){
  document.getElementById('fechaCompra').value=hoyISO();
  document.getElementById('instrumento').value='';
  document.getElementById('direccion').value='Largo';
  document.getElementById('moneda').value='USD';
  document.getElementById('precioCompra').value='';
  document.getElementById('cantidadCompra').value='';
  document.getElementById('importeCompraManual').value='';
  document.getElementById('importeCompraCalc').value='';
  document.getElementById('stop').value='';
  document.getElementById('tp').value='';
  document.getElementById('motivoEntrada').value='Ruptura';
  document.getElementById('notasEntrada').value='';
  document.getElementById('fechaVenta').value='';
  document.getElementById('precioVenta').value='';
  document.getElementById('cantidadVendida').value='';
  document.getElementById('importeVentaCalc').value='';
  document.getElementById('motivoSalida').value='Sin salida aún';
  document.getElementById('notasSalida').value='';
}
function cancelarEdicion(){ editingId=null; document.getElementById('editBanner').classList.add('hidden'); document.getElementById('guardar').textContent='Guardar operación'; estadoOperacion='abierta'; limpiarFormularioBase(); applyEstadoUI(); }
function limpiar(){cancelarEdicion()}

function guardar(){
  const f=formData();
  if(!f.instrumento || !f.precioCompra){ alert('Rellena al menos: instrumento y precio de compra.'); return; }
  if(!f.cantidadCompra && !f.importeCompraManual){ alert('Pon cantidad comprada o importe compra manual.'); return; }
  if(f.estado!=='abierta' && !f.precioVenta){ alert('Si la operación está parcial o cerrada, indica el precio de venta.'); return; }
  if(f.estado==='parcial' && !f.cantidadVendida){ alert('Para una operación parcial, indica cuántas acciones vendiste.'); return; }
  const idx=trades.findIndex(t=>t.id===f.id);
  if(idx>=0) trades[idx]=f; else trades.unshift(f);
  save(); cancelarEdicion(); alert('Operación guardada.');
}
function borrar(id){ if(!confirm('¿Borrar operación?')) return; trades=trades.filter(t=>t.id!==id); save(); }
function editar(id){
  const t=trades.find(x=>x.id===id); if(!t) return;
  editingId=id; document.getElementById('editBanner').classList.remove('hidden'); document.getElementById('guardar').textContent='Guardar cambios'; estadoOperacion=t.estado||'abierta';
  document.getElementById('fechaCompra').value=t.fechaCompra||hoyISO();
  document.getElementById('instrumento').value=t.instrumento||'';
  document.getElementById('direccion').value=t.direccion||'Largo';
  document.getElementById('moneda').value=t.moneda||'USD';
  document.getElementById('precioCompra').value=t.precioCompra||'';
  document.getElementById('cantidadCompra').value=t.cantidadCompra||'';
  document.getElementById('importeCompraManual').value=t.importeCompraManual||'';
  document.getElementById('stop').value=t.stop||'';
  document.getElementById('tp').value=t.tp||'';
  document.getElementById('motivoEntrada').value=t.motivoEntrada||'Ruptura';
  document.getElementById('notasEntrada').value=t.notasEntrada||'';
  document.getElementById('fechaVenta').value=t.fechaVenta||'';
  document.getElementById('precioVenta').value=t.precioVenta||'';
  document.getElementById('cantidadVendida').value=t.cantidadVendida||'';
  document.getElementById('motivoSalida').value=t.motivoSalida||'Sin salida aún';
  document.getElementById('notasSalida').value=t.notasSalida||'';
  applyEstadoUI();
  vista='nuevo';
  document.querySelectorAll('[data-view]').forEach(b=>b.classList.toggle('active',b.dataset.view===vista));
  document.querySelectorAll('.view').forEach(v=>v.classList.add('hidden'));
  document.getElementById('view-nuevo').classList.remove('hidden');
  window.scrollTo({top:0,behavior:'smooth'});
}
function cerrarOperacion(id){ const t=trades.find(x=>x.id===id); if(!t) return; editar(id); estadoOperacion='cerrada'; document.getElementById('motivoSalida').value='Take profit'; applyEstadoUI(); }
function copiarTicker(sym){ if(!sym) return; navigator.clipboard?.writeText(sym).then(()=>alert('Ticker copiado: '+sym)).catch(()=>alert('Ticker: '+sym)); }
function exportar(){ const blob=new Blob([JSON.stringify(trades,null,2)],{type:'application/json'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='diario-trading-pro-v10.json'; a.click(); URL.revokeObjectURL(a.href); }
function importar(file){ const reader=new FileReader(); reader.onload=()=>{ try{ const parsed=JSON.parse(reader.result); if(!Array.isArray(parsed)) throw new Error(); trades=parsed; save(); alert('Datos importados correctamente.'); } catch{ alert('El archivo no es válido.'); } }; reader.readAsText(file); }

function renderMetrics(list){
  const s=summary(list);
  setText('mOps',s.operaciones); setText('mEur',money(s.eur,'EUR')); setText('mUsd',money(s.usd,'USD')); setText('mWr',s.winRate+'%');
  setText('bGanadoras',s.ganadoras); setText('bPerdedoras',s.perdedoras); setText('bEur',money(s.eur,'EUR')); setText('bUsd',money(s.usd,'USD'));
}
function renderHistory(list){
  const box=document.getElementById('history');
  if(!list.length){ box.innerHTML='<div class="muted">No hay operaciones en este filtro.</div>'; return; }
  box.innerHTML=list.map(t=>{
    const r=resultadoTrade(t), buyQty=cantidadComprada(t), sellQty=cantidadVendida(t), mon=t.moneda||'USD', estado=t.estado||'abierta';
    return `<div class="trade">
      <div class="trade-top">
        <div>
          <button class="ticker-btn" type="button" onclick="copiarTicker('${esc(t.instrumento||'')}')">${esc(t.instrumento||'—')}</button>
          <div class="badges">
            <span class="badge">${esc(t.direccion)}</span>
            <span class="badge">${esc(t.fechaCompra||'—')}</span>
            <span class="badge">${esc(mon)}</span>
            <span class="badge">Estado: ${esc(estado)}</span>
          </div>
        </div>
        <div class="${r>=0?'good':'bad'}" style="font-size:28px;font-weight:900">${estado==='abierta'?'Abierta':(r>=0?'+':'')+money(r,mon)}</div>
      </div>
      <div class="badges" style="margin-top:12px">
        <span class="badge">Precio compra: ${fmtNum(t.precioCompra)}</span>
        <span class="badge">Cantidad comprada: ${fmtNum(buyQty)}</span>
        <span class="badge">Importe compra: ${money(importeCompra(t),mon)}</span>
        ${estado!=='abierta' ? `<span class="badge">Fecha venta: ${esc(t.fechaVenta||'—')}</span><span class="badge">Precio venta: ${fmtNum(t.precioVenta)}</span><span class="badge">Cantidad vendida: ${fmtNum(sellQty)}</span><span class="badge">Importe venta: ${money(importeVenta(t),mon)}</span>` : ''}
        <span class="badge">Stop: ${fmtNum(t.stop)}</span>
        <span class="badge">TP: ${fmtNum(t.tp)}</span>
        <span class="badge">Riesgo real: ${riesgoRealTrade(t)?money(riesgoRealTrade(t),mon):'—'}</span>
      </div>
      <div class="legend" style="margin-top:10px">Motivo entrada: ${esc(t.motivoEntrada||'—')}</div>
      <div class="legend">Notas entrada: ${esc(t.notasEntrada||'Sin notas')}</div>
      <div class="legend">Motivo salida: ${esc(t.motivoSalida||'—')}</div>
      <div class="legend">Notas salida: ${esc(t.notasSalida||'Sin notas')}</div>
      <div class="actions" style="margin-top:12px">
        ${estado==='abierta' ? `<button class="btn small primary" type="button" onclick="cerrarOperacion(${t.id})">Cerrar</button>` : ''}
        <button class="btn small ghost" type="button" onclick="editar(${t.id})">Editar</button>
        <button class="btn small secondary" type="button" onclick="borrar(${t.id})">Borrar</button>
      </div>
    </div>`;
  }).join('');
}
function renderEquity(list){
  const box=document.getElementById('equityChart');
  const cerradas=list.filter(t=>(t.estado||'abierta')!=='abierta');
  if(!cerradas.length){ box.innerHTML='<div class="muted">No hay operaciones con venta para la curva de capital.</div>'; return; }
  let acc=0;
  const data=cerradas.slice().reverse().map(t=>{ acc+=resultadoTrade(t); return {x:(t.fechaVenta||t.fechaCompra||'').slice(5), y:acc}; });
  const w=box.clientWidth||700, h=260, pad=28;
  const ys=data.map(d=>d.y); let min=Math.min(...ys), max=Math.max(...ys); if(min===max){min-=1;max+=1}
  const x=i=>pad + i*((w-pad*2)/Math.max(1,data.length-1)); const y=v=>h-pad - ((v-min)*((h-pad*2)/(max-min)));
  const pts=data.map((d,i)=>`${x(i)},${y(d.y)}`).join(' ');
  box.innerHTML=`<svg width="100%" height="${h}" viewBox="0 0 ${w} ${h}">
    <line x1="${pad}" y1="${pad}" x2="${pad}" y2="${h-pad}" stroke="#334766"/>
    <line x1="${pad}" y1="${h-pad}" x2="${w-pad}" y2="${h-pad}" stroke="#334766"/>
    <polyline fill="none" stroke="#7bffbf" stroke-width="4" points="${pts}" />
    ${data.map((d,i)=>`<circle cx="${x(i)}" cy="${y(d.y)}" r="3.5" fill="#5ea8ff"/>`).join('')}
  </svg><div class="legend">La curva usa operaciones parciales y cerradas. Las abiertas no entran.</div>`;
}
function renderMotivos(list){
  const box=document.getElementById('motivosChart');
  if(!list.length){ box.innerHTML='<div class="muted">No hay datos de motivos.</div>'; return; }
  const map={}; list.forEach(t=>map[t.motivoEntrada]=(map[t.motivoEntrada]||0)+1);
  const items=Object.entries(map).sort((a,b)=>b[1]-a[1]); const max=Math.max(...items.map(x=>x[1]));
  box.innerHTML=items.map(([k,v])=>`<div style="margin-bottom:12px"><div class="actions"><strong>${esc(k)}</strong><div class="spacer"></div><span class="muted">${v}</span></div><div style="height:12px;background:#0a1528;border-radius:999px;overflow:hidden;border:1px solid #22314e;margin-top:6px"><div style="width:${(v/max)*100}%;height:100%;background:linear-gradient(90deg,#5ea8ff,#7bffbf)"></div></div></div>`).join('');
}
function render(){ const list=filtered(); renderMetrics(list); renderHistory(list); renderEquity(list); renderMotivos(list); }
function bindTabs(){
  document.querySelectorAll('[data-view]').forEach(btn=>btn.addEventListener('click',()=>{vista=btn.dataset.view;document.querySelectorAll('[data-view]').forEach(b=>b.classList.toggle('active',b.dataset.view===vista));document.querySelectorAll('.view').forEach(v=>v.classList.add('hidden'));document.getElementById('view-'+vista).classList.remove('hidden');if(vista==='panel') render();}));
  document.querySelectorAll('[data-filter]').forEach(btn=>btn.addEventListener('click',()=>{filtro=btn.dataset.filter;document.querySelectorAll('[data-filter]').forEach(b=>b.classList.toggle('active',b.dataset.filter===filtro));render();}));
}
bindTabs(); bindForm(); render();
document.getElementById('guardar').addEventListener('click',guardar);
document.getElementById('limpiar').addEventListener('click',limpiar);
document.getElementById('exportar').addEventListener('click',exportar);
document.getElementById('importar').addEventListener('change',e=>{ if(e.target.files&&e.target.files[0]) importar(e.target.files[0]); e.target.value=''; });
</script>
</body>
</html>
